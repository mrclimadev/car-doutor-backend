# ── Fonte dos dados geoespaciais ──────────────────────────────────────────────
# "local"  → lê de ../data-pipeline/processed/vectors (dev)
# "s3"     → lê diretamente do S3 via pyarrow + s3fs (produção)
DATA_SOURCE=local

# ── S3 (obrigatório quando DATA_SOURCE=s3) ────────────────────────────────────
S3_BUCKET=car-doutor-geodata
S3_PREFIX=bases/mt/vectors
AWS_REGION=us-east-1
# Credenciais: use IAM role em produção; para dev local use aws configure
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── LLM (Anthropic Claude) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-SUA_CHAVE_AQUI

# ── API ───────────────────────────────────────────────────────────────────────
PORT=8000
# CORS: origens permitidas separadas por vírgula
# CORS_ORIGINS=https://car-doutor.vercel.app,http://localhost:5173
